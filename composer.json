{
  "name": "tlf-e/pixicato-bundle",
  "description": "A Symfony bundle for validating Brazilian PIX keys.",
  "type": "symfony-bundle",
  "keywords": ["symfony", "pix", "brazil", "cpf", "cnpj","phone","email","validation"],
  "version": "1.0.4",
  "license": "MIT",
  "repositories": [
    {"type": "git", "url": "git@github.com:TLF-E/cpf-cnpj.git"}  
],
  "autoload": {
    "psr-4": {
      "TLFE\\PIXicato\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TLFE\\PIXicato\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
         "name":"TLFE",
         "email":"constantinos.sergiou@tlf.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "symfony/framework-bundle": "^6.0|^7.0",
    "symfony/validator": "^6.0|^7.0",
    "giggsey/libphonenumber-for-php": "^8.0",
    "tlf-e/cpf-cnpj": "1.0.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0",
    "symfony/phpunit-bridge": "^6.0|^7.0",
    "squizlabs/php_codesniffer": "*"
  },
  "scripts": {
    "test": "phpunit",
    "test-debug": "phpunit --debug"
  }
}
